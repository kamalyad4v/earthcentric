# Database (Neon PostgreSQL connection string)
DATABASE_URL="postgresql://neondb_owner:mock_password@ep-mock-pool-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_minimum_32_characters"

# Email (Nodemailer SMTP — works with Gmail, Outlook, or any SMTP provider)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="EarthCentric <your_email@gmail.com>"

